# Environment configuration
#
# Values with bw: prefix are fetched from Bitwarden (see scripts/administration/env/expand_env.sh)
#
# Syntax:
#   VAR=bw:<item-name>                      # Gets password field
#   VAR=bw:<item-name>/password             # Gets password field (explicit)
#   VAR=bw:<item-name>/username             # Gets username field
#   VAR=bw:<item-name>/notes                # Gets secure notes
#   VAR=bw:<item-name>/uri                  # Gets first URI
#   VAR=bw:<item-name>/field/<field-name>   # Gets custom field

# Bitwarden folder to fetch secrets from
BW_FOLDER=Lavender

ENV=local
TOKEN_SECRET_KEY="secret"

# Port allocation: 1300-1310 reserved for this project
# 1300 - Frontend
# 1301 - Gateway (API)
# 1302 - Redis
# 1303 - PostgreSQL
FRONTEND_URL="http://localhost:1300"
FRONTEND_PORT=1300
FULLSTACK_API_URL="http://gateway:1301/"
GATEWAY_PORT=1301
REDIS_PORT=1302
POSTGRES_PORT=1303

POSTGRES_USER=fullstack_user
POSTGRES_PASSWORD=password
POSTGRES_DB=fullstack-db

TOKEN_KEY_IDENTIFIER="fullstack-access-token"
TOKEN_SIGNING_SECRET="secret"

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@fullstack_db:5432/${POSTGRES_DB}

# Google OAuth
GOOGLE_CLIENT_ID=bw:Google/field/client_id
GOOGLE_CLIENT_SECRET=bw:Google/field/client_secret

# Redis (for Celery) - internal docker network uses default port
# Using database 1 to avoid conflicts with other projects on db 0
REDIS_URL=redis://redis:6379/1

# Slack Integration
SLACK_BOT_TOKEN=bw:Slack/field/bot_token

OPENAI_API_KEY=bw:OpenAI/field/api_key

# Google Cloud Storage (Sieve onsite bucket)
GCS_BUCKET_NAME=product-onsite
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcs-service-account.json